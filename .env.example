# Spatial Asset Management System - Environment Template
# Copy to backend/.env and fill in with your actual values

# ========================
# DATABASE CONFIGURATION
# ========================
DATABASE_URL=postgresql://user:password@host:port/database
# Example for Supabase:
# DATABASE_URL=postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# ========================
# YOLO MODEL CONFIG
# ========================
YOLOV8_MODEL_PATH=./models/yolov8l-seg.pt
YOLOV8_CONFIDENCE_THRESHOLD=0.5
YOLOV8_IOU_THRESHOLD=0.45

# ========================
# API SERVER CONFIG
# ========================
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
DEBUG=False

# ========================
# CORS CONFIGURATION
# ========================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ========================
# FILE UPLOADS
# ========================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800

# ========================
# LLM INTEGRATION (OPTIONAL)
# ========================
GEMINI_API_KEY=your-gemini-api-key-here

# ========================
# NEO4J GRAPH DATABASE (OPTIONAL - Phase 2+)
# ========================
NEO4J_URI=neo4j+s://ubuntu-1234.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ========================
# LOGGING
# ========================
LOG_LEVEL=INFO
